#
# data.env
#

# Service Gateway, Internet Gateway, Nat Gateway, DRG
SGW_NAME="sgw"
NGW_NAME="ngw"

# Private IPs
SECONDARY_IP_START=20
SECONDARY_IP_END=80

#-------#
# VCN-A #
#-------#
VCN_NAME="vcn-a"
VCN_DNS_NAME="vcna"
VCN_CIDR="10.100.0.0/16"
VCN_DHCP_NAME="dhcp_options"

SUBNPRV_NAME="subnprv"
SUBNPRV_DNS_NAME="subnprv"
SUBNPRV_CIDR="10.100.0.0/20"
SUBNPRV_RT_NAME="rt_subnprv"
SUBNPRV_SECL_NAME="secl-1_subnprv"

#-------------#
# Firewall #1 #
#-------------#
FW_1_NAME="fw-1"
FW_1_HOSTNAME="$FW_1_NAME"
FW_1_IP="10.100.0.10"
FW_1_VNIC_NAME="fw-1-vnic-1"
FW_1_SHAPE="VM.Standard.A1.Flex"
FW_1_OCPU="2"
FW_1_MEM="4"

#-------------#
# Firewall #2 #
#-------------#
FW_2_NAME="fw-2"
FW_2_HOSTNAME="$FW_2_NAME"
FW_2_IP="10.100.10.10"
FW_2_VNIC_NAME="fw-2-vnic-1"
FW_2_SHAPE="VM.Standard.A1.Flex"
FW_2_OCPU="2"
FW_2_MEM="4"

